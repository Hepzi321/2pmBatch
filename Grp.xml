<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite">
  <test thread-count="5" name="Test">
	
	<groups>
		<define name="day-group">
			<include name="Smoke"></include>
		</define>
		
		<define name="Quarterly-group">
			<include name="Regression"></include>
			<include name="Smoke"></include>
		</define>
		
		<define name="Monthly-group">
			<include name="Smoke"></include>
			<include name="Sanity"></include>
			<include name="Regression"></include>
		</define>
	<run>
		<include name="Monthly-group"></include>
	</run>	
		
	</groups>
	
    <classes>
      <class name="org.DemoTestNG.Class_1"/>
      <class name="org.DemoTestNG.Class_2"/>
      <class name="org.DemoTestNG.Class_3"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
